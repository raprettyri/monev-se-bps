generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pembelian {
  id        String   @id @default(cuid())
  noBast    String
  tanggal   String
  barang    String?
  jumlah    Int
  penyedia  String
  dokumen   String?
  createdAt DateTime @default(now())
}

model Pemakaian {
  id        String   @id @default(cuid())
  tanggal   String
  nama      String
  kegiatan  String
  barang    String
  jumlah    Int
  dokumen   String?
  createdAt DateTime @default(now())
}
