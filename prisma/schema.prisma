generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pembelian {
  id        String   @id @default(cuid())
  noBast    String
  tanggal   String
  barang    String?
  jumlah    Int
  penyedia  String
  dokumen   String?
  createdAt DateTime @default(now())
}

model Pemakaian {
  id        String   @id @default(cuid())
  tanggal   String
  nama      String
  kegiatan  String
  barang    String
  jumlah    Int
  dokumen   String?
  createdAt DateTime @default(now())
}

model TransferKeluar {
  id        String   @id @default(cuid())
  noBast    String
  tanggal   String
  tujuan    String
  barang    String
  jumlah    Int
  status    String   @default("Dikirim")
  dokumen   String?
  createdAt DateTime @default(now())
}

model TransferMasuk {
  id        String   @id @default(cuid())
  noBast    String   // Nomor BAST yang sudah ttd 2 pihak
  tanggal   String
  pengirim  String   // Misal: BPS Provinsi Aceh
  barang    String
  jumlah    Int
  dokumen   String?  // Surat Pengantar / BAST ttd 2 pihak
  createdAt DateTime @default(now())
}
