generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pembelian {
  id          String   @id @default(cuid())
  noBast      String
  tanggal     String
  barang      String?
  jumlah      Int      // Total keseluruhan
  baik        Int      @default(0) // Kualitas Baik
  rusakRingan Int      @default(0) // Kualitas Rusak Ringan
  rusakBerat  Int      @default(0) // Kualitas Rusak Berat
  penyedia    String
  dokumen     String?
  createdAt   DateTime @default(now())
}

model Pemakaian {
  id        String   @id @default(cuid())
  noBukti   String
  tanggal   String
  nama      String
  kegiatan  String
  barang    String
  jumlah    Int
  dokumen   String?
  createdAt DateTime @default(now())
}

model TransferKeluar {
  id        String   @id @default(cuid())
  noBast    String
  tanggal   String
  tujuan    String
  barang    String
  jumlah    Int
  status    String   @default("Dikirim")
  dokumen   String?
  createdAt DateTime @default(now())
}

model TransferMasuk {
  id        String   @id @default(cuid())
  noBast    String
  tanggal   String
  pengirim  String
  barang    String
  jumlah    Int
  dokumen   String?
  createdAt DateTime @default(now())
}
