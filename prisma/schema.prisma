generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Pembelian {
  id        String   @id @default(cuid())
  noBast    String
  tanggal   String
  jumlah    Int
  penyedia  String
  dokumen   String
  createdAt DateTime @default(now())
}

model Pemakaian {
  id        String   @id @default(cuid())
  tanggal   String
  nama      String   // Nama pegawai yang memakai
  kegiatan  String   // Untuk kegiatan apa (misal: Rapat Teknis SE)
  barang    String   // Jenis barang (misal: Rompi, Tas, atau ATK)
  jumlah    Int
  createdAt DateTime @default(now())
}
